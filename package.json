{
  "name": "mu-agent",
  "version": "0.1.0",
  "description": "A persistent, observable crew of pi agents running in one tmux session per workstream, coordinated through a built-in task DAG.",
  "type": "module",
  "license": "MIT",
  "author": "Martin Trojer <martin.trojer@gmail.com>",
  "homepage": "https://github.com/martintrojer/mu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martintrojer/mu.git"
  },
  "bugs": {
    "url": "https://github.com/martintrojer/mu/issues"
  },
  "keywords": [
    "tmux",
    "agents",
    "ai",
    "orchestration",
    "task-graph",
    "pi-coding-agent",
    "pi-package"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "mu": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "docs",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test && bash scripts/grep-name-without-workstream.sh",
    "lint:guards": "bash scripts/grep-name-without-workstream.sh",
    "lint:fix": "biome check --write src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "execa": "^9.5.2",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
